# ── Protobuf fix (required on Anaconda / systems with a broken C extension) ──
# Forces the pure-Python protobuf implementation instead of the C extension.
# Safe on all platforms; has no effect when the C extension is healthy.
PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python

# ── Live NYC Parks source ────────────────────────────────────────────────────
NYC_PARKS_BASE=https://www.nycgovparks.org

# ── Cache / rate limiting ─────────────────────────────────────────────────────
CACHE_TTL_S=3600
CATALOG_TTL_S=86400
REQUEST_DELAY_S=0.03
SNAPSHOT_CONCURRENCY=10
MAX_RANGE_DAYS=14
